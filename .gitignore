# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tooling state
.claude/
dev.log

# image-gen sidecars (generated next to each image)
public/assets/images/**/*.prompt.txt

# image-gen api key (per-machine, never committed)
tools/image-gen/.env

# legacy image bundle, not used by Next.js
public/assets/images.zip
